# Template de variáveis de ambiente
# Copie para .env e preencha com os valores reais — NUNCA commite o .env

# Supabase — service_role key do painel: Settings > API
SUPABASE_SERVICE_KEY=eyJ...sua_service_role_key_aqui

# Domínio público (sem https://) — usado pelo Traefik e CORS
DOMAIN=app.seudominio.com.br

# Origens permitidas pelo CORS (com https://)
ALLOWED_ORIGINS=https://app.seudominio.com.br

# Nome da rede Docker do Traefik — verifique com: docker network ls | grep traefik
TRAEFIK_NETWORK=traefik-net

# N8N + Z-API: Webhook do N8N para enviar WhatsApp quando nova cotação chegar.
# Deixe em branco para desabilitar (o servidor continua funcionando sem erro).
# Configuração do N8N:
#   1. Crie um workflow com trigger "Webhook" (POST)
#   2. Adicione um node "HTTP Request" para cada loja em {{$json.lojas}}
#      apontando para a API do Z-API: POST https://api.z-api.io/instances/{INSTANCE}/token/{TOKEN}/send-text
#      body: { "phone": "55{{loja.telefone}}", "message": "..." }
#   3. Cole a URL do webhook aqui
N8N_WEBHOOK_URL=https://seu-n8n.dominio.com.br/webhook/cotacao-nova
